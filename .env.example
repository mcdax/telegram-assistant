# Copy to .env and fill in the API key(s) for the LLM provider(s) you use.
# Only the provider matching [llm].model in config.toml is actually read.

# Log verbosity for the assistant itself (DEBUG | INFO | WARNING | ERROR).
# DEBUG traces every event, marker match, and pipeline stage; very useful
# when a trigger appears to do nothing.
LOG_LEVEL=INFO

# Optional: override [llm].model from config.toml. When set, this wins over
# the config file. Useful for switching models without editing config.toml.
# LLM_MODEL=anthropic:claude-sonnet-4-6

# Optional: override [telegram].api_id / api_hash / session from config.toml.
# Same precedence — env wins when both are present. Useful for keeping
# secrets entirely out of config.toml.
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_SESSION=

# Anthropic (anthropic:claude-sonnet-4-6 etc.)
ANTHROPIC_API_KEY=

# OpenAI (openai:gpt-4o etc.)
# OPENAI_API_KEY=

# Google (google-gla:gemini-1.5-pro etc.)
# GOOGLE_API_KEY=

# Mistral, Groq, etc. — add as needed. pydantic-ai reads the matching
# provider env var automatically.

# ---- Optional: OpenAI-compatible backend for the drafting module ----
# When [modules.drafting.openai] is set in config.toml, drafting calls
# that endpoint directly (bypassing pydantic-ai). The api_key_env value in
# config.toml names the env var that holds the actual key — typically one
# of the names below. This is independent from any ANTHROPIC / OPENAI / ...
# key above used by the correcting module's pydantic-ai path.
# DRAFTING_OPENAI_API_KEY=
